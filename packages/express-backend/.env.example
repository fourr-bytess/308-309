## Gmail SMTP (Option B - real email sending)
##
## 1) Enable 2-Step Verification in your Google Account
## 2) Create an App Password and paste it into SMTP_PASS
##    (NOT your normal Gmail password)
##
## Restart the backend after changing this file.

# Required for real email sending (otherwise we log the code in console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password_here

# Email sender shown in the email
EMAIL_FROM=your_gmail@gmail.com

# Used to hash verification codes in the database (set a strong random string)
EMAIL_VERIFICATION_SECRET=change-me-to-a-long-random-string

# Dev-only: allow entering code 000000 to bypass verification
# (Ignored in production)
EMAIL_VERIFICATION_BYPASS=false

